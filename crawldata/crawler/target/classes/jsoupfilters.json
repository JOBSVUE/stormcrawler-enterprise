{
  "com.digitalpebble.stormcrawler.parse.JSoupFilters": [
    {
      "class": "com.digitalpebble.stormcrawler.jsoup.XPathFilter",
      "name": "XPathFilter",
      "params": {
        "canonical": "//link[@rel='canonical']/@href",
        "parse.description": [
          "//meta[@property='og:description']/@content",
          "//meta[@name='description']/@content",
          "//meta[@name='Description']/@content"
        ],
        "parse.title": [
          "//meta[@property='og:title']/@content",
          "//title/text()",
          "//meta[@name='title']/@content",
          "//h1/text()"
        ],
        "parse.keywords": [
          "//meta[@name='keywords']/@content",
          "//meta[@name='Keywords']/@content"
        ],
        "parse.author": [
          "//meta[@name='author']/@content",
            "//meta[@name='Author']/@content",
            "//*[@itemprop='author']/@content",
            "//*[@itemprop='author']//text()"
        ],
        "parse.publishedDate": [
          "//meta[@property='article:published_time']/@content",
          "//meta[@itemprop='datePublished']/@content",
          "//*[@itemprop='datePublished']/@content",
          "//meta[@name='pubdate']/@content",
          "//time[@itemprop='datePublished']/@datetime",
          "//time/@datetime",
          "//meta[@name='publishedDate']/@content"
        ],
        "parse.lastModified": [
          "//meta[@property='og:updated_time']/@content",
          "//meta[@itemprop='dateModified']/@content",
          "//*[@itemprop='dateModified']/@content",
          "//meta[@http-equiv='last-modified']/@content",
          "//meta[@name='last-modified']/@content"
        ]
      }
    },
    {
      "class": "com.digitalpebble.stormcrawler.jsoup.TextExtractionFilter",
      "name": "TextExtractionFilter",
      "params": {
        "includePattern": [
          "ARTICLE",
          "MAIN",
          "SECTION",
          "DIV[id~=(?i)(content|article|main|body|page)]",
          "BODY"
        ],
        "excludePattern": [
          "SCRIPT",
          "STYLE",
          "NOSCRIPT",
          "HEADER",
          "FOOTER",
          "NAV",
          "FORM"
        ]
      }
    },
    {
      "class": "com.digitalpebble.stormcrawler.jsoup.LinkParseFilter",
      "name": "LinkParseFilter",
      "params": {
        "pattern": "//a[@href and not(starts-with(@href,'javascript:')) and not(starts-with(@href,'mailto:')) and not(starts-with(@href,'tel:')) and not(starts-with(@href,'#'))]"
      }
    }
  ]
}
